{{- $pages := where site.RegularPages "Section" "r" -}}
{{- $pages = where $pages "Draft" false -}}
{{- $pages = sort $pages "Date" "desc" -}}
{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.Title }} ({{ site.Language.Label }})</title>
    <link>{{ site.Home.Permalink }}</link>
    <description>{{ i18n "meta.description.main" }}</description>
    <language>{{ site.Language.Lang }}</language>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    <atom:link href="{{ printf "%s%s" site.Home.Permalink "index.xml" }}" rel="self" type="application/rss+xml" />
    {{- range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ .Title }}</description>
    </item>
    {{- end }}
  </channel>
</rss>
